{
  "name": "indexa",
  "version": "0.1.0",
  "description": "Declarative database indexer — describe what to index in one YAML file; Indexa handles incremental sync, checkpointing, idempotency, reorg handling, and an auto-generated REST query API.",
  "type": "module",
  "license": "MIT",
  "author": "IndexaDB",
  "homepage": "https://github.com/IndexaDB/indexa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IndexaDB/indexa.git"
  },
  "bugs": {
    "url": "https://github.com/IndexaDB/indexa/issues"
  },
  "keywords": [
    "indexer",
    "declarative",
    "etl",
    "incremental-sync",
    "sqlite",
    "postgres",
    "evm",
    "blockchain",
    "reorg",
    "rest-api",
    "checkpoint"
  ],
  "bin": {
    "indexa": "./bin/indexa.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "demo": "node bin/indexa.js deploy --config examples/orders/indexa.config.yaml",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:reorg": "node --test test/reorg.test.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "optionalDependencies": {
    "pg": "^8.11.0",
    "ethers": "^6.17.0"
  }
}
